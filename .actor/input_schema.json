{
    "title": "Telegram OSINT Scraper",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "channels": {
            "title": "Telegram Channels",
            "type": "array",
            "editor": "stringList",
            "prefill": ["bbcnews", "reuters"]
        },
        "hoursBack": {
            "title": "Hours Back",
            "type": "integer",
            "default": 24,
            "minimum": 1,
            "maximum": 168,
            "editor": "number"
        },
        "maxPosts": {
            "title": "Max Posts Per Channel",
            "type": "integer",
            "default": 80,
            "minimum": 10,
            "maximum": 500,
            "editor": "number"
        },
        "makeWebhookUrl": {
            "title": "Make.com Webhook URL",
            "type": "string",
            "editor": "textfield"
        }
    },
    "required": ["channels"]
}
